# =============================================================================
# GOS — Variables de entorno
# Copiá este archivo a .env y completá los valores ( .env está en .gitignore )
# =============================================================================

# ── Entorno ──────────────────────────────────────────────────────────────────
# development | production | testing
FLASK_ENV=development

# ── Seguridad (obligatorio en producción) ────────────────────────────────────
# Generá una clave aleatoria: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production

# Contraseña del admin inicial (mín. 8 caracteres en producción)
GOS_ADMIN_PASSWORD=admin123

# Clave para POST /gos/objetivos/api/v1/admin/import-db (header X-Import-Secret)
# Generá una distinta a la contraseña de admin
GOS_IMPORT_SECRET=

# ── Base de datos ────────────────────────────────────────────────────────────
# Desarrollo: SQLite local (opcional; por defecto instance/gos.db)
# DATABASE_URL=sqlite:///instance/gos.db
# Producción Render: PostgreSQL (Render lo inyecta automáticamente)
# DATABASE_URL=postgresql://user:pass@host/db

# Ruta alternativa al SQLite principal (opcional)
# GOS_DATABASE_PATH=C:/ruta/a/gos.db

# ── Bootstrap (primer deploy) ────────────────────────────────────────────────
GOS_ADMIN_EMAIL=admin@demo.local
GOS_ADMIN_NOMBRE=Administrador
GOS_EMPRESA_NOMBRE=Empresa Demo S.A.

# ── Desarrollo local ─────────────────────────────────────────────────────────
# true = entrar sin login (solo FLASK_ENV=development)
GOS_AUTO_LOGIN=true

# Usuario creado automáticamente cuando GOS_AUTO_LOGIN=true
GOS_DEV_LOGIN_EMAIL=admin@gos.local
GOS_DEV_LOGIN_PASSWORD=gos
GOS_DEV_LOGIN_NOMBRE=Usuario GOS
GOS_DEV_EMPRESA_NOMBRE=GOS

# ── Módulos — rutas de datos ─────────────────────────────────────────────────
# HWO: JSON de datasets (default: instance/hwo/)
# GOS_HWO_DATA_DIR=

# Vacaciones: SQLite del módulo (default: instance/vacaciones/indicadores.db)
# GOS_VACACIONES_DB_PATH=

# ── Correo SMTP (notificaciones capacitación) ────────────────────────────────
# GOS_SMTP_HOST=smtp.gmail.com
# GOS_SMTP_PORT=587
# GOS_SMTP_USER=
# GOS_SMTP_PASSWORD=
# GOS_SMTP_FROM=noreply@empresa.com
# GOS_SMTP_TLS=true

# Objetivos: Excel maestro de KPIs para importación
# GOS_KPI_EXCEL_PATH=C:/ruta/al/archivo.xlsx

# ── Scripts de deploy / backup ───────────────────────────────────────────────
# URL del servicio en Render (para subir backup)
GOS_RENDER_URL=https://gos-objetivos.onrender.com

# SQLite local a subir con scripts/subir_backup_a_render.py
# GOS_LOCAL_DB_PATH=instance/gos.db

# Importación directa SQLite → Postgres (scripts/importar_local_a_render.py)
# RENDER_DATABASE_URL=

# ── IA (futuro) ──────────────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
